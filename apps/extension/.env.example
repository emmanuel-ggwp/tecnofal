# Proveedor de backend (§21): supabase (activo/principal) | nhost (respaldo)
VITE_PROVIDER=supabase

# --- Supabase --- (Settings → API del proyecto)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Nhost --- (solo si VITE_PROVIDER=nhost; respaldo, no es el flujo activo)
VITE_NHOST_SUBDOMAIN=
VITE_NHOST_REGION=us-east-1
